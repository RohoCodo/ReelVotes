rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }

    // Events collection with subcollections for votes and movie summaries
    match /events/{eventId} {
      // Create event document if it doesn't exist
      allow read: if true;
      allow create: if true;
      
      // Individual votes collection
      match /votes/{voteId} {
        allow read: if true;
        allow create: if true;
      }
      
      // Movie summaries collection
      match /movies/{movieId} {
        allow read: if true;
        allow write: if true;
      }
    }

    // Legacy votes collection (for backward compatibility if needed)
    match /votes/{docId} {
      allow read: if true;
      allow write: if true;
    }

    match /reactions/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /takes/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /community_proposals/{docId} {
      allow read, write: if signedIn();
    }

    match /threads/{threadId} {
      allow read, write: if signedIn();
      match /messages/{msgId} {
        allow read, write: if signedIn();
      }
    }
  }
}